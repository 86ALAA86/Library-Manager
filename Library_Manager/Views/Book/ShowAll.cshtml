@model List<clsBook_BLL>
<body>
	<div class="container mt-4">
		<h1>All Available Books</h1>
		<a asp-controller="Book" asp-action="Create" class="btn btn-primary btn-lg">Add Book </a>
	    <a asp-controller="BorrowRecord" asp-action="ShowAll" class="btn btn-primary btn-lg">Borrow Records </a>

		<br />

		<table class="table table-striped table-hover">
			<thead class="table-dark">
				<tr>
					<th>Book ID</th><th>Title</th><th>Author</th><th>Genre</th><th colspan="2">Actions</th>
				</tr>

			</thead>
			<tbody>
				@foreach(clsBook_BLL B in @Model)
				{
					<tr>
						<td>@B.BookID</td><td>@B.Title</td><td>@B.Auther</td><td>@B.Genre</td>

						<td>
							<a asp-controller="Book" asp-action="Edit" asp-route-id="@B.BookID"
							class="btn btn-warning"> Edit</a>

						</td>

						<td>
							<form method="post" asp-action="Delete" asp-controller="Book">
								<button onclick="return confirm('Are you sure you want to delete this book?')" 
									class="btn btn-danger" name="id" value="@B.BookID">
									Delete
								</button>


							</form>
							

						</td>

					</tr>
				}



			</tbody>



		</table>


	</div>




</body>